82E47; --gm-active: #8B1E32; --gm-subtle: rgba(164, 36, 59, 0.15); --gm-border: rgba(164, 36, 59, 0.4); --gm-glow: rgba(164, 36, 59, 0.25); --player-primary: #2563EB; --player-hover: #3B82F6; --player-active: #1D4ED8; --player-subtle: rgba(37, 99, 235, 0.15); --player-border: rgba(37, 99, 235, 0.4); --player-glow: rgba(37, 99, 235, 0.25); --success: #22C55E; --success-subtle: rgba(34, 197, 94, 0.15); --warning: #F59E0B; --warning-subtle: rgba(245, 158, 11, 0.15); --danger: #EF4444; --danger-subtle: rgba(239, 68, 68, 0.15); --info: #06B6D4; --info-subtle: rgba(6, 182, 212, 0.15); --border-subtle: rgba(255, 255, 255, 0.08); --border-default: rgba(255, 255, 255, 0.12); --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3); --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.4); --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.5); --radius-none: 0; --radius-sm: 2px; --radius-md: 4px; --radius-lg: 6px; --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; --font-display: 'Montserrat', var(--font-sans); }\n* { box-sizing: border-box; }\nbody { background: var(--bg-primary); color: var(--text-primary); font-family: var(--font-sans); margin: 0px; padding: 0px; }\n.card { background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: var(--radius-md); }\n.card-gm { background: var(--bg-card); border: 1px solid var(--gm-border); border-radius: var(--radius-md); }\n.card-player { background: var(--bg-card); border: 1px solid var(--player-border); border-radius: var(--radius-md); }\n.btn { padding: 10px 20px; border: none; border-radius: var(--radius-sm); font-weight: 600; font-size: 14px; cursor: pointer; transition: 0.15s; display: inline-flex; align-items: center; justify-content: center; gap: 8px; }\n.btn-gm { background: var(--gm-primary); color: var(--text-primary); }\n.btn-gm:hover { background: var(--gm-hover); }\n.btn-player { background: var(--player-primary); color: var(--text-primary); }\n.btn-player:hover { background: var(--player-hover); }\n.btn-outline-gm { background: transparent; border: 1px solid var(--gm-primary); color: var(--gm-primary); }\n.btn-outline-gm:hover { background: var(--gm-subtle); }\n.btn-outline-player { background: transparent; border: 1px solid var(--player-primary); color: var(--player-primary); }\n.btn-outline-player:hover { background: var(--player-subtle); }\n.tab { padding: 12px 20px; background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: var(--radius-none); color: var(--text-secondary); font-weight: 500; font-size: 14px; cursor: pointer; transition: 0.15s; }\n.tab-gm.active, .tab-gm:hover { background: var(--gm-subtle); border-color: var(--gm-primary); color: var(--text-primary); }\n.tab-player.active, .tab-player:hover { background: var(--player-subtle); border-color: var(--player-primary); color: var(--text-primary); }\n.input { padding: 10px 14px; background: var(--bg-secondary); border: 1px solid var(--border-default); border-radius: var(--radius-sm); color: var(--text-primary); font-size: 14px; transition: border-color 0.15s; }\n.input:focus { outline: none; border-color: var(--player-primary); }\n.input-gm:focus { border-color: var(--gm-primary); }\n.panel { background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: var(--radius-md); padding: 20px; }\n.panel-gm { border-left: 3px solid var(--gm-primary); }\n.panel-player { border-left: 3px solid var(--player-primary); }\n.glass { background: rgba(30, 30, 34, 0.8); backdrop-filter: blur(12px); border: 1px solid var(--border-subtle); border-radius: var(--radius-md); }\n.glass-gm { background: rgba(164, 36, 59, 0.08); border-color: var(--gm-border); }\n.glass-player { background: rgba(37, 99, 235, 0.08); border-color: var(--player-border); }\n.section-header { font-family: var(--font-display); font-weight: 800; font-size: 20px; color: var(--text-primary); margin-bottom: 16px; display: flex; align-items: center; gap: 10px; }\n.section-header-gm { color: var(--gm-primary); }\n.section-header-player { color: var(--player-primary); }\n.divider { height: 1px; background: var(--border-subtle); margin: 20px 0px; }\n.divider-vertical { width: 1px; background: var(--border-default); align-self: stretch; }\n.badge { padding: 4px 10px; font-size: 11px; font-weight: 600; border-radius: var(--radius-sm); text-transform: uppercase; letter-spacing: 0.5px; }\n.badge-gm { background: var(--gm-subtle); color: var(--gm-primary); border: 1px solid var(--gm-border); }\n.badge-player { background: var(--player-subtle); color: var(--player-primary); border: 1px solid var(--player-border); }\n.stat-block { background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: var(--radius-sm); padding: 12px; text-align: center; }\n.stat-value { font-size: 24px; font-weight: 800; font-family: var(--font-display); color: var(--text-primary); }\n.stat-label { font-size: 10px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 4px; }\n@keyframes fadeIn { \n  0% { opacity: 0; transform: translateY(10px); }\n  100% { opacity: 1; transform: translateY(0px); }\n}\n.animate-in { animation: 0.3s ease-out 0s 1 normal none running fadeIn; }\n:root { --rq-bg-main: var(--bg-primary); --rq-bg-panel: var(--bg-card); --rq-bg-panel-soft: var(--bg-secondary); --rq-text-main: var(--text-primary); --rq-text-soft: var(--text-secondary); --rq-text-muted: var(--text-muted); --rq-gold: #E7B94C; --rq-border: var(--border-subtle); }\n.rq-panel { background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: var(--radius-md); padding: 24px; }\n.rq-card { background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: var(--radius-md); padding: 16px; }\n.rq-title { font-family: var(--font-display); font-weight: 700; font-size: 24px; color: var(--text-primary); margin: 0px 0px 8px; }\n.rq-muted { color: var(--text-muted); font-size: 14px; }\n.rq-stat { background: var(--bg-secondary); border