.4s ease-out 0s 1 normal forwards running slideInUp; }\n.stagger-1 { animation-delay: 0.05s; }\n.stagger-2 { animation-delay: 0.1s; }\n.stagger-3 { animation-delay: 0.15s; }\n.stagger-4 { animation-delay: 0.2s; }\n.stagger-5 { animation-delay: 0.25s; }\n.stagger-6 { animation-delay: 0.3s; }\n.stagger-7 { animation-delay: 0.35s; }\n.stagger-8 { animation-delay: 0.4s; }\n.animate-stagger { opacity: 0; }\n.transition-smooth { transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1); }\n.transition-colors { transition: background-color 0.2s, border-color 0.2s, color 0.2s; }\n.transition-transform { transition: transform 0.2s; }\n.hover-lift:hover { transform: translateY(-2px); box-shadow: rgba(0, 0, 0, 0.3) 0px 4px 12px; }\n.hover-glow:hover { box-shadow: rgba(225, 29, 72, 0.3) 0px 0px 20px; }\n.hover-scale:hover { transform: scale(1.02); }\n.page-enter { opacity: 0; transform: translateY(10px); }\n.page-enter-active { opacity: 1; transform: translateY(0px); transition: opacity 0.3s, transform 0.3s; }\n.card-animated { opacity: 0; transform: translateY(10px); animation: 0.4s ease-out 0s 1 normal forwards running fadeInUp; }\n.tab-content-enter { opacity: 0; transform: translateX(10px); }\n.tab-content-enter-active { opacity: 1; transform: translateX(0px); transition: opacity 0.25s, transform 0.25s; }\n.modal-backdrop { animation: 0.2s ease-out 0s 1 normal forwards running fadeIn; }\n.modal-content { animation: 0.3s ease-out 0s 1 normal forwards running scaleIn; }\n.skeleton { background-image: ; background-position-x: ; background-position-y: ; background-repeat: ; background-attachment: ; background-origin: ; background-clip: ; background-color: ; background-size: 200% 100%; animation: 1.5s ease 0s infinite normal none running shimmer; }\n.btn-press:active { transform: scale(0.98); }\n.mobile-toggle { transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1); }\n.mobile-toggle-active { background: var(--accent-red); color: white; }\n.slide-panel { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); }\n.slide-panel-hidden { transform: translateX(-100%); }\n.slide-panel-visible { transform: translateX(0px); }\n@keyframes lightTrailLeft { \n  0% { transform: translateX(-100%) scaleX(0.3); opacity: 0; }\n  5% { opacity: 1; }\n  95% { opacity: 1; }\n  100% { transform: translateX(200vw) scaleX(1.5); opacity: 0; }\n}\n@keyframes lightTrailRight { \n  0% { transform: translateX(200vw) scaleX(0.3); opacity: 0; }\n  5% { opacity: 1; }\n  95% { opacity: 1; }\n  100% { transform: translateX(-100%) scaleX(1.5); opacity: 0; }\n}\n@keyframes lightTrailDiagonal { \n  0% { transform: translate(-100%, 100%) rotate(-15deg) scaleX(0.5); opacity: 0; }\n  5% { opacity: 0.9; }\n  95% { opacity: 0.9; }\n  100% { transform: translate(200vw, -100vh) rotate(-15deg) scaleX(1.2); opacity: 0; }\n}\n@keyframes lightTrailDiagonalReverse { \n  0% { transform: translate(200vw, 100%) rotate(15deg) scaleX(0.5); opacity: 0; }\n  5% { opacity: 0.9; }\n  95% { opacity: 0.9; }\n  100% { transform: translate(-100%, -100vh) rotate(15deg) scaleX(1.2); opacity: 0; }\n}\n@keyframes trailPulse { \n  0%, 100% { filter: blur(1px) brightness(1); }\n  50% { filter: blur(2px) brightness(1.3); }\n}\n.tron-bg { position: relative; overflow: hidden; }\n.tron-bg::before { content: \"\"; position: absolute; inset: 0px; pointer-events: none; z-index: 0; }\n.light-trail { position: absolute; height: 1px; width: 200px; pointer-events: none; z-index: 1; border-radius: 1px; }\n.light-trail-blue { background: linear-gradient(90deg, transparent 0%, rgb(6, 182, 212) 20%, rgb(255, 255, 255) 50%, rgb(59, 130, 246) 80%, transparent 100%); box-shadow: rgb(6, 182, 212) 0px 0px 4px, rgb(6, 182, 212) 0px 0px 8px, rgba(6, 182, 212, 0.8) 0px 0px 15px, rgba(6, 182, 212, 0.4) 0px 0px 30px; animation: 1.8s linear 0s infinite normal none running lightTrailLeft; }\n.light-trail-blue-2 { background: linear-gradient(90deg, transparent 0%, rgb(34, 211, 238) 20%, rgb(255, 255, 255) 50%, rgb(14, 165, 233) 80%, transparent 100%); box-shadow: rgb(34, 211, 238) 0px 0px 4px, rgb(34, 211, 238) 0px 0px 10px, rgba(34, 211, 238, 0.6) 0px 0px 20px; animation: 2.2s linear 0.5s infinite normal none running lightTrailLeft; }\n.light-trail-blue-3 { background: linear-gradient(90deg, transparent 0%, rgb(59, 130, 246) 20%, rgb(255, 255, 255) 50%, rgb(6, 182, 212) 80%, transparent 100%); box-shadow: rgb(59, 130, 246) 0px 0px 6px, rgba(59, 130, 246, 0.8) 0px 0px 12px; animation: 2.5s linear 1s infinite normal none running lightTrailDiagonal; }\n.light-trail-red { background: linear-gradient(90deg, transparent 0%, rgb(225, 29, 72) 20%, rgb(255, 255, 255) 50%, rgb(244, 63, 94) 80%, transparent 100%); box-shadow: rgb(225, 29, 72) 0px 0px 4px, rgb(225, 29, 72) 0px 0px 8px, rgba(225, 29, 72, 0.8) 0px 0px 15px, rgba(225, 29, 72, 0.4) 0px 0px 30px; animation: 2s linear 0s infinite normal none running lightTrailRight; }\n.light-trail-red-2 { background: linear-gradient(90deg, transparent 0%, rgb(251, 113, 133) 20%, rgb(255, 255, 255) 50%, rgb(244, 63, 94) 80%, transparent 100%); box-shadow: rgb(251, 113, 133) 0px 0px 4px, rgb(251, 113, 133) 0px 0px 10px, rgba(251, 113, 133, 0.6) 0px 0px 20px; animation: 2.4s linear 0.7s infinite normal none running lightTrailRight; }\n.light-trail-red-3 { background: linear-gradient(90deg, transparent 0%, rgb(225, 29, 72) 20%, rgb(255, 255, 255) 50%, rgb(220, 38, 38) 80%, transparent 100%); box-shadow: rgb(225, 29, 72) 0px 0px 6px, rgba(225, 29, 72, 0.8) 0px 0px 12px; animation: 2.8s linear 1.2s infinite normal none running lightTrailDiagonalReverse; }\n.tron-grid { position: absolute; inset: 0px; background-image: linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px); background-size: 50px 50px; pointer-events: none; z-index: 0; }\n.tron-grid-blue { background-image: linear-gradient(rgba(6, 182, 212, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(6, 182, 212, 0.03) 1px, transparent 1px); 